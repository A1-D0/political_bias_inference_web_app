{
    "name": "@usnewsweb/shared",
    "version": "1.0.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./schemas/*": {
            "types": "./dist/schemas/*.d.ts",
            "default": "./dist/schemas/*.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsc -p tsconfig.json"
    },
    "dependencies": {
        "zod": "^4.3.5",
        "typescript": "^5.9.3"
    }
}
